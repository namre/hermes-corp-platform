# ======================================================================
# Hermes Corp Platform — пример конфигурации
# Скопируйте в .env. Со ЗАГЛУШКАМИ менять ничего не обязательно —
# значения CHANGE_ME нужны только когда подключаете реальные системы.
# .env в git НЕ коммитится (см. .gitignore).
# ======================================================================

# ---------- Базовый агент ----------
# Образ агента Hermes (NousResearch). Соберите/опубликуйте свой или
# используйте публичный тег.
HERMES_IMAGE=nousresearch/hermes-agent:latest

# ---------- Внутренняя авторизация между сервисами ----------
# Общий секрет, которым брокеры проверяют, что запрос пришёл от proxy/runtime,
# а не снаружи. Сгенерируйте: openssl rand -hex 32
BROKER_INTERNAL_AUTH=CHANGE_ME_openssl_rand_hex_32

# Ключ к admin-API агента (proxy ↔ hermes-agent). openssl rand -hex 32
HERMES_API_KEY=CHANGE_ME_openssl_rand_hex_32

# ---------- LLM gateway ----------
# OpenAI-совместимый эндпоинт. LiteLLM, OpenRouter, vLLM, локальный прокси.
LLM_BASE_URL=http://llm-gateway:4000/v1
LLM_API_KEY=CHANGE_ME_llm_provider_key
# Запасной провайдер на случай недоступности основного (необязательно).
FALLBACK_API_KEY=

# ---------- Каталог сотрудников (corp-dir-broker) ----------
# ЗАГЛУШКА читает локальный JSON и НЕ ходит наружу.
# Когда подключаете реальный HRIS/LDAP — заполните и перепишите брокер.
CORP_API_URL=https://example.invalid/api/users          # CHANGE_ME при реальной интеграции
CORP_API_TOKEN=                                          # CHANGE_ME при реальной интеграции
CORP_DIR_REFRESH_HOURS=3

# ---------- Облако/файлы (files-broker) ----------
# ЗАГЛУШКА хранит файлы в памяти. Реальная интеграция: Yandex360/GDrive/S3.
FILES_OAUTH_CLIENT_ID=                                   # CHANGE_ME при реальной интеграции
FILES_OAUTH_CLIENT_SECRET=                               # CHANGE_ME при реальной интеграции

# ---------- Таск-трекер (tasks-broker) ----------
# ЗАГЛУШКА отдаёт фейковые задачи. Реальная интеграция: Kaiten/Jira/YouTrack.
TASKS_API_URL=https://example.invalid/api                # CHANGE_ME при реальной интеграции
TASKS_API_TOKEN=                                         # CHANGE_ME при реальной интеграции

# ---------- Telegram (опционально) ----------
# Если канал доступа — Telegram. Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=                                      # CHANGE_ME если используете Telegram
TELEGRAM_WEBHOOK_SECRET=                                 # openssl rand -hex 32

# ---------- Память ----------
# Внешний сервис памяти (паттерн в memory/README.md). Пусто = память выключена.
MEMORY_PROVIDER_URL=
MEMORY_PROVIDER_TOKEN=
MEMORY_CORP_BANK=corp:example      # read-only корп-банк; наполняется отдельным конвейером

# ---------- Key-broker (изоляция per-user LLM-ключей) ----------
# Секрет доступа к /v1/keys. Provisioner использует его при запросе виртуального ключа.
# Генерация: openssl rand -hex 32
KEYBROKER_SYSTEM_SECRET=CHANGE_ME_openssl_rand_hex_32

# ---------- Telegram MUX ----------
# Секрет для генерации per-user fake-токенов Telegram.
# Реальный TELEGRAM_BOT_TOKEN в user-runtime не попадает — только HMAC-производная.
# Генерация: openssl rand -hex 32
TELEGRAM_MUX_SECRET=CHANGE_ME_openssl_rand_hex_32
# Числовой bot_id (@BotFather показывает в первой части токена, например 7654321000)
TELEGRAM_MUX_BOT_ID=CHANGE_ME_bot_id_number

# ---------- User-runtime конфигурация ----------
# Режим инъекции config.yaml: copy (безопаснее, дефолт) | mount
USER_RUNTIME_CONFIG_MODE=copy
# Режим передачи auth: none (рекомендуется — ключи из key-broker) | copy | mount
USER_RUNTIME_AUTH_MODE=none
# Язык ответов агентов по умолчанию (ISO 639-1: en, ru, ...)
RUNTIME_LANGUAGE=en

# ---------- Web UI (OpenWebUI) ----------
ADMIN_UI_PASSWORD=CHANGE_ME_admin_password

# ---------- Admin panel ----------
# Название/бренд в шапке панели оператора (нейтральный дефолт).
ADMIN_PANEL_BRAND=Corp AI
